{
  "name": "@guardbot/framework",
  "version": "2.0.0",
  "description": "A simple framework made for building discord bots with discord.js.",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf build",
    "build": "yarn run clean && tsup",
    "test": "tsx tests/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardbotgg/framework.git"
  },
  "keywords": [
    "discord",
    "framework",
    "discord.js"
  ],
  "license": "MIT",
  "author": "Aniket",
  "homepage": "https://github.com/guardbotgg/framework#readme",
  "bugs": {
    "url": "https://github.com/guardbotgg/framework/issues"
  },
  "peerDependencies": {
    "discord.js": "^14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "discord.js": "^14",
    "rimraf": "^5.0.5",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
